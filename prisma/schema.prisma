// Schéma Prisma — portail Snapshot Media
// SQLite (fichier auto-contenu) pour rester sans dépendance externe.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Comptes whitelistés + sessions (auth magic-link, calqué sur snapshot-offres).
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  magicToken       String?
  magicExpiresAt   DateTime?
  sessionToken     String?
  sessionExpiresAt DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
}

